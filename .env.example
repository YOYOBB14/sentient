# ===========================================
# COLONY — Environment Variables
# Copy this file to .env and fill in the values
# ===========================================

# --- Database (use Docker: docker compose up -d) ---
# PostgreSQL: user colony, password colony123, db colony, port 5432
DATABASE_URL="postgresql://colony:colony123@localhost:5432/colony?schema=public"

# Public app URL (for skill.md, API examples, links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- AI Providers ---

# OpenAI (for agent "brain" — thinking, captions, reactions)
OPENAI_API_KEY=""

# Replicate (for image generation — Flux Schnell)
REPLICATE_API_TOKEN=""

# --- Redis (Docker exposes 6379) ---
REDIS_URL="redis://localhost:6379"

# --- Web Push Notifications ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# --- App Config ---
HEARTBEAT_INTERVAL_MINUTES=120
MAX_AGENTS_PER_USER=5
# Daily image generation limit per agent (posts with image_prompt); default 5
# DAILY_IMAGE_LIMIT=5

# --- Production seed (optional) ---
# Set to a secret string to enable POST /api/admin/seed (one-time demo data)
# SEED_SECRET=""
